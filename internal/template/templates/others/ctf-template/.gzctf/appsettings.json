{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "Host=db:5432;Database=gzctf;Username=postgres;Password=postgres",
    "RedisCache": "cache:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Loki": {
      "Enable": false,
      "EndpointUri": "http://loki:3100",
      "Labels": [
        {
          "Key": "app",
          "Value": "gzctf"
        }
      ],
      "PropertiesAsLabels": [
        "app"
      ],
      "Credentials": {
        "Login": "login",
        "Password": "password"
      },
      "Tenant": "my-tenant",
      "MinimumLevel": "Trace"
    }
  },
  "Telemetry": {
    "Prometheus": {
      "Enable": false,
      "Port": 3000,
      "TotalNameSuffixForCounters": false
    },
    "OpenTelemetry": {
      "Enable": false,
      "Protocol": "Grpc",
      "EndpointUri": "http://jaeger-collector:4317"
    },
    "AzureMonitor": {
      "Enable": false,
      "ConnectionString": "InstrumentationKey=12345678-abcd-abcd-abcd-12345678..."
    },
    "Console": {
      "Enable": false
    }
  },
  "EmailConfig": {
    "SenderAddress": "noreply@1pc.tf",
    "SenderName": "noreply",
    "UserName": "noreply@1pc.tf",
    "Password": "-",
    "Smtp": {
      "Host": "1pc.tf",
      "Port": 587
    }
  },
  "XorKey": "{{.XorKey}}",
  "ContainerProvider": {
    "Type": "Docker",
    "PortMappingType": "PlatformProxy",
    "EnableTrafficCapture": true,
    "PublicEntry": "{{.PublicEntry}}",
    "DockerConfig": {
      "SwarmMode": false,
      "ChallengeNetwork": "challenges",
      "Uri": "unix:///var/run/docker.sock",
      "UserName": "",
      "Password": ""
    },
    "KubernetesConfig": {
      "Namespace": "gzctf-challenges",
      "ConfigPath": "kube-config.yaml",
      "AllowCIDR": [
        "10.0.0.0/8"
      ],
      "DNS": [
        "8.8.8.8",
        "223.5.5.5"
      ]
    }
  },
  "RequestLogging": true,
  "DisableRateLimit": true,
  "RegistryConfig": {
    "UserName": "",
    "Password": "",
    "ServerAddress": ""
  },
  "CaptchaConfig": {
    "Provider": "CloudflareTurnstile",
    "SiteKey": "",
    "SecretKey": ""
  },
  "ForwardedOptions": {
    "ForwardedHeaders": 5,
    "ForwardLimit": 1,
    "ForwardedForHeaderName": "X-Forwarded-For",
    "TrustedNetworks": [
      "172.30.0.0/16"
    ],
    "TrustedProxies": [
      "172.30.0.2"
    ]
  },
  "Kestrel": {
    "Endpoints": {},
    "Limits": {
      "MaxResponseBufferSize": 2048,
      "MaxRequestBufferSize": 1048576,
      "MaxRequestLineSize": 8192,
      "MaxRequestHeadersTotalSize": 32768,
      "MaxRequestHeaderCount": 100,
      "MaxRequestBodySize": 300000000,
      "KeepAliveTimeout": "0.0:5:0",
      "RequestHeadersTimeout": "0.0:5:0",
      "MaxConcurrentConnections": null,
      "MaxConcurrentUpgradedConnections": null
    },
    "AddServerHeader": true,
    "AllowResponseHeaderCompression": true,
    "AllowSynchronousIO": false,
    "AllowAlternateSchemes": false,
    "DisableStringReuse": false,
    "ConfigurationLoader": null
  },
  "HoneypotConfig": {
    "Enabled": true,
    "ListenAddress": "0.0.0.0",
    "Ports": [
      { "Name": "ssh",       "Port": 2222,  "Banner": "SSH-2.0-OpenSSH_8.4p1 backup-server", "Enabled": true },
      { "Name": "mysql",     "Port": 3306,  "Banner": "", "Enabled": true },
      { "Name": "postgres",  "Port": 5432,  "Banner": "", "Enabled": true },
      { "Name": "redis",     "Port": 6379,  "Banner": "", "Enabled": true },
      { "Name": "memcached", "Port": 11211, "Banner": "", "Enabled": true },
      { "Name": "mongo",     "Port": 27017, "Banner": "", "Enabled": true },
      { "Name": "elastic",   "Port": 9200,  "Banner": "", "Enabled": true }
    ],
    "ChainEnabled": true,
    "ChainThreshold": 3,
    "ChainWindowMinutes": 30,
    "ChainSweepIntervalSeconds": 60
  },
  "FlagEgressConfig": {
    "Enabled": true,
    "WindowSeconds": 60,
    "MinPacketDataLength": 8,
    "FlushIntervalSeconds": 5
  },
  "CheatDetectionConfig": {
    "LogContainerAccess": true,
    "DelayedSubmissionThresholdMinutes": 60,
    "InstantSubmitThresholdSeconds": 3
  }
}
